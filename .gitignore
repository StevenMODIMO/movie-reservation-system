# ==========================================
# Environment variables
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# macOS / Windows
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# IDEs
# ==========================================
.vscode/
.idea/

# ==========================================
# Logs
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Temporary files
# ==========================================
*.tmp
*.temp

# ==========================================
# ============================
# Next.js (mrs-frontend)
# ============================
mrs-frontend/node_modules/
mrs-frontend/.next/
mrs-frontend/out/
mrs-frontend/build/
mrs-frontend/coverage/
mrs-frontend/.vercel/

# Package managers
mrs-frontend/.pnp
mrs-frontend/.pnp.*
mrs-frontend/.yarn/*
!mrs-frontend/.yarn/patches/
!mrs-frontend/.yarn/plugins/
!mrs-frontend/.yarn/releases/
!mrs-frontend/.yarn/versions/

# TypeScript
mrs-frontend/*.tsbuildinfo
mrs-frontend/next-env.d.ts

# ==========================================
# FastAPI (mrs-backend)
# ==========================================

# Virtual environments
mrs-backend/.venv/
mrs-backend/venv/
mrs-backend/env/
mrs-backend/ENV/

# Python cache
mrs-backend/__pycache__/
mrs-backend/**/*.py[cod]
mrs-backend/*$py.class

# Compiled extensions
mrs-backend/*.so

# Build / Packaging
mrs-backend/build/
mrs-backend/dist/
mrs-backend/*.egg-info/
mrs-backend/.eggs/

# Databases
mrs-backend/*.db
mrs-backend/*.sqlite3

# Testing
mrs-backend/.pytest_cache/
mrs-backend/.coverage
mrs-backend/htmlcov/

# Type checking & linting
mrs-backend/.mypy_cache/
mrs-backend/.ruff_cache/

# Jupyter
mrs-backend/.ipynb_checkpoints/

# Alembic cache
mrs-backend/alembic/versions/__pycache__/
